[
  { "text": "山月不替人作答，却陪人走一程。", "type": "random", "enabled": true },
  { "text": "风经过纸页，像时间轻轻翻身。", "type": "random", "enabled": true },
  { "text": "世界很大，也容得下一盏小灯。", "type": "random", "enabled": true },
  { "text": "月亮不着急赶路，夜色也会慢慢亮。", "type": "random", "enabled": true },
  { "text": "人被理解以后，心会慢慢松开。", "type": "random", "enabled": true },
  { "text": "你不必照很远，先照亮眼前。", "type": "random", "enabled": true },
  { "text": "回忆不是把人拽住，而是替人标路。", "type": "random", "enabled": true },
  { "text": "把今天安放好，明天会来接你。", "type": "random", "enabled": true },
  { "text": "水面很静时，月光更容易落下。", "type": "random", "enabled": true },
  { "text": "有些晚风不说话，却把心吹开。", "type": "random", "enabled": true },
  { "text": "山路不问归期，只把人慢慢带深。", "type": "random", "enabled": true },
  { "text": "小灯不大，也能照清一张桌子。", "type": "random", "enabled": true },
  { "text": "云走得慢，天反而显得更宽。", "type": "random", "enabled": true },
  { "text": "夜色不是催促，它只是让人安静。", "type": "random", "enabled": true },
  { "text": "有些答案像月光，要慢一点才看清。", "type": "random", "enabled": true },
  { "text": "把心放低一点，世界会柔和一点。", "type": "random", "enabled": true },
  { "text": "风不替人选择，只替人把尘吹开。", "type": "random", "enabled": true },
  { "text": "一页纸翻过去，日子就有了回声。", "type": "random", "enabled": true },
  { "text": "水声很轻，足够让急躁慢下来。", "type": "random", "enabled": true },
  { "text": "不必追着光跑，站稳也会被照亮。", "type": "random", "enabled": true },
  { "text": "灯一明，事便不算止。", "type": "start", "enabled": true },
  { "text": "风过案头，时光便轻移半寸。", "type": "start", "enabled": true },
  { "text": "纸翻一页，今日便又向前。", "type": "start", "enabled": true },
  { "text": "案上有光，心便有处安放。", "type": "start", "enabled": true },
  { "text": "字写得慢些，意思反倒更真。", "type": "start", "enabled": true },
  { "text": "人一坐定，诸事便渐次成形。", "type": "start", "enabled": true },
  { "text": "不必求疾，流水自有去处。", "type": "start", "enabled": true },
  { "text": "一灯一案，亦可自成天地。", "type": "start", "enabled": true },
  { "text": "纸尚未阖，今日便仍可续。", "type": "start", "enabled": true },
  { "text": "风不相催，人却可随之而行。", "type": "start", "enabled": true },
  { "text": "山不解答，倒教人心先静。", "type": "push", "enabled": true },
  { "text": "月色无言，却把长夜徐徐铺开。", "type": "push", "enabled": true },
  { "text": "云行得缓，天便显得更深。", "type": "push", "enabled": true },
  { "text": "灯火不盛，却足以照完此页。", "type": "push", "enabled": true },
  { "text": "水声若轻，心绪便不那么急。", "type": "push", "enabled": true },
  { "text": "远山自定，人心亦可随之稍稳。", "type": "push", "enabled": true },
  { "text": "风翻纸页，似替人把今日续完。", "type": "push", "enabled": true },
  { "text": "夜色深一层，万物反倒清明。", "type": "push", "enabled": true },
  { "text": "有光之处，诸事自会渐渐归拢。", "type": "push", "enabled": true },
  { "text": "不必急赴远方，路自会慢慢现前。", "type": "push", "enabled": true },
  { "text": "风停了一下，世界也轻了一下。", "type": "random", "enabled": true },
  { "text": "人走在路上，事情就会慢慢成形。", "type": "push", "enabled": true },
  { "text": "灯下坐久了，心也会安定。", "type": "random", "enabled": true },
  { "text": "有些路，是在安静里走完的。", "type": "random", "enabled": true },
  { "text": "事情不急的时候，反而更清楚。", "type": "push", "enabled": true },
  { "text": "风从窗边过去，像替人整理了一遍世界。", "type": "random", "enabled": true },
  { "text": "一张桌子，也能装下今天。", "type": "start", "enabled": true },
  { "text": "写下来的东西，会慢慢长出意义。", "type": "push", "enabled": true },
  { "text": "不被打断的时候，人会更像自己。", "type": "random", "enabled": true },
  { "text": "光在纸上，人就不算迷路。", "type": "push", "enabled": true }
]
